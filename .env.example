# Database connection URL for PostgreSQL/Supabase.
# Leave blank to fall back to the Go Indexer's built-in in-memory mock repository.
DATABASE_URL=postgresql://postgres:password@localhost:5432/edutrace

# RPC URL for Polygon Amoy Testnet.
# Defaults to https://rpc-amoy.polygon.technology if left blank in docker-compose.yml.
RPC_URL=https://rpc-amoy.polygon.technology
